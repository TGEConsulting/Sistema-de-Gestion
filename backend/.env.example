DATABASE_URL="postgresql://sgc_user:sgc_password@localhost:5432/gestion_sgc?schema=public"
JWT_SECRET="cambia-este-secreto-por-uno-largo-y-aleatorio"
JWT_EXPIRES_IN="8h"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Login con Google (Google Cloud Console → APIs & Services → Credentials →
# OAuth 2.0 Client ID de tipo "Web application"). Debe ser el MISMO valor
# que VITE_GOOGLE_CLIENT_ID en el frontend.
GOOGLE_CLIENT_ID=""

# Google Cloud Storage, para archivos adjuntos (documentos, evidencias,
# informes). Bucket con objetos de lectura pública, igual que el disco local
# que reemplaza. GCS_CREDENTIALS_JSON es el contenido completo (una sola
# línea) del JSON de la cuenta de servicio, no una ruta de archivo — así
# funciona también en entornos serverless sin sistema de archivos persistente.
GCS_PROJECT_ID=""
GCS_BUCKET=""
GCS_CREDENTIALS_JSON=""

# Secreto compartido para proteger GET /api/cron/alertas cuando lo invoca
# Vercel Cron (o cualquier scheduler externo) en vez del cron local.
CRON_SECRET="cambia-este-secreto-tambien"
